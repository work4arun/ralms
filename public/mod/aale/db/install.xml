<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/aale/db" VERSION="20260414" COMMENT="AALE — Active Adaptive Learning Environment"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>

    <!-- ══════════════════════════════════════════════════════════════════════
         LAYER 1 — Main instance (one row per activity added to a course).
         Holds: activity name, booking window open/close dates,
         and group/individual student restriction settings.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale" COMMENT="AALE activity instances — Layer 1 configuration">
      <FIELDS>
        <FIELD NAME="id"               TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="course"           TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="name"             TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""
               COMMENT="Activity name — mandatory Layer 1 field"/>
        <FIELD NAME="intro"            TYPE="text"              NOTNULL="false"/>
        <FIELD NAME="introformat"      TYPE="int"  LENGTH="4"  NOTNULL="true"  DEFAULT="1"/>
        <!-- Booking window (restrict access dates) -->
        <FIELD NAME="bookingopen"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Unix TS when booking opens for students (Layer 1 restrict access)"/>
        <FIELD NAME="bookingclose"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Unix TS when booking closes for students (Layer 1 restrict access)"/>
        <!-- Student restriction -->
        <FIELD NAME="restrict_type"    TYPE="char" LENGTH="16" NOTNULL="true"  DEFAULT="all"
               COMMENT="all | groups | individuals — who can see and book slots"/>
        <FIELD NAME="restrict_groups"  TYPE="text"             NOTNULL="false"
               COMMENT="JSON array of Moodle group IDs when restrict_type=groups"/>
        <FIELD NAME="restrict_users"   TYPE="text"             NOTNULL="false"
               COMMENT="JSON array of Moodle user IDs when restrict_type=individuals"/>
        <!-- Coin rewards global toggle -->
        <FIELD NAME="coins_enabled"    TYPE="int"  LENGTH="2"  NOTNULL="true"  DEFAULT="1"
               COMMENT="1 = reward coin system active for this activity"/>
        <!-- Allow students to cancel their bookings -->
        <FIELD NAME="allow_cancellation" TYPE="int" LENGTH="2" NOTNULL="true"  DEFAULT="1"
               COMMENT="1 = students may cancel their own bookings"/>
        <FIELD NAME="timecreated"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course" UNIQUE="false" FIELDS="course"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         LAYER 2 — Slot details (per faculty / per CPA session).
         Dates and times are stored as human-readable display strings
         (e.g. "15 Apr 2026", "10:00 AM – 12:00 PM") as requested.
         Multiple slots per activity; mode = class | cpa.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_slots" COMMENT="Layer-2 slot details — faculty, venue, date/time display, mode">
      <FIELDS>
        <FIELD NAME="id"               TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="aaleid"           TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="FK → aale.id"/>
        <FIELD NAME="slotmode"         TYPE="char" LENGTH="8"  NOTNULL="true"  DEFAULT="class"
               COMMENT="class | cpa"/>

        <!-- Faculty -->
        <FIELD NAME="teacherid"        TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Enrolled teacher assigned to this slot"/>
        <FIELD NAME="show_faculty_to_students" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="1"
               COMMENT="1=visible to students, 0=hidden (used in CPA mode)"/>

        <!-- Venue and schedule (stored as display strings) -->
        <FIELD NAME="venue"            TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""
               COMMENT="Room / lab number — display string"/>
        <FIELD NAME="classdate"        TYPE="char" LENGTH="64"  NOTNULL="true" DEFAULT=""
               COMMENT="Date display string e.g. '15 Apr 2026'"/>
        <FIELD NAME="classtime"        TYPE="char" LENGTH="64"  NOTNULL="true" DEFAULT=""
               COMMENT="Time display string e.g. '10:00 AM – 12:00 PM'"/>

        <!-- Slot capacity -->
        <FIELD NAME="totalslots"       TYPE="int"  LENGTH="6"  NOTNULL="true"  DEFAULT="60"
               COMMENT="Total number of student slots available (e.g. 40 or 60)"/>

        <!-- ── CLASS MODE FIELDS ── -->
        <FIELD NAME="att_sessions"     TYPE="int"  LENGTH="4"  NOTNULL="true"  DEFAULT="1"
               COMMENT="CLASS MODE: number of attendance sessions (1–20); system generates that many columns"/>

        <!-- ── CPA MODE FIELDS ── -->
        <FIELD NAME="track"            TYPE="char" LENGTH="128" NOTNULL="true" DEFAULT=""
               COMMENT="CPA MODE: subject/track name e.g. Java, Python, DSA"/>
        <FIELD NAME="track_details"    TYPE="text"              NOTNULL="false"
               COMMENT="CPA MODE: optional description for the track"/>
        <FIELD NAME="available_levels" TYPE="text"              NOTNULL="false"
               COMMENT="CPA MODE: JSON array of levels selectable by students e.g. [2,5,7]"/>
        <FIELD NAME="assessmenttype"   TYPE="char" LENGTH="8"   NOTNULL="true"  DEFAULT="coding"
               COMMENT="CPA MODE: coding | mcq"/>
        <FIELD NAME="questions_per_student" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="2"
               COMMENT="CPA MODE: number of questions randomly assigned per student"/>
        <FIELD NAME="pass_percentage"  TYPE="int"  LENGTH="4"  NOTNULL="true"  DEFAULT="60"
               COMMENT="CPA MODE (MCQ): pass threshold percentage e.g. 60"/>
        <FIELD NAME="coins_per_level"  TYPE="text"              NOTNULL="false"
               COMMENT="CPA MODE: JSON object {level: coins} awarded on W1 e.g. {&quot;1&quot;:10,&quot;2&quot;:20}"/>
        <FIELD NAME="mcq_questionbank_id" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
               COMMENT="CPA MODE (MCQ): Moodle question category ID for random question pool"/>
        <FIELD NAME="cpa_activity_id"  TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="CPA MODE: linked mod_cpa instance ID (0 = not yet assigned)"/>

        <FIELD NAME="status"           TYPE="char" LENGTH="16" NOTNULL="true"  DEFAULT="active"
               COMMENT="active | cancelled | completed"/>
        <FIELD NAME="createdby"        TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"  TYPE="primary" FIELDS="id"/>
        <KEY NAME="aaleid"   TYPE="foreign" FIELDS="aaleid" REFTABLE="aale" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="aaleid"    UNIQUE="false" FIELDS="aaleid"/>
        <INDEX NAME="teacherid" UNIQUE="false" FIELDS="teacherid"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         Student bookings — one active booking per slot per student.
         One student cannot hold two bookings for the same slot.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_bookings" COMMENT="Student slot bookings">
      <FIELDS>
        <FIELD NAME="id"                 TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="aaleid"             TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="FK → aale.id"/>
        <FIELD NAME="slotid"             TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="FK → aale_slots.id"/>
        <FIELD NAME="userid"             TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <!-- CPA-mode booking extras -->
        <FIELD NAME="level_selected"     TYPE="int"  LENGTH="4"  NOTNULL="true"  DEFAULT="0"
               COMMENT="CPA MODE: level chosen by student (1–10); 0 for class mode"/>
        <FIELD NAME="track_selected"     TYPE="char" LENGTH="128" NOTNULL="true" DEFAULT=""
               COMMENT="CPA MODE: track chosen by student"/>
        <FIELD NAME="questions_assigned" TYPE="text"              NOTNULL="false"
               COMMENT="CPA MODE: JSON array of aale_qassign IDs assigned to this student"/>
        <FIELD NAME="status"             TYPE="char" LENGTH="16" NOTNULL="true"  DEFAULT="booked"
               COMMENT="booked | cancelled | attended | absent"/>
        <FIELD NAME="timecreated"        TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"       TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="slotid"  TYPE="foreign" FIELDS="slotid"  REFTABLE="aale_slots" REFFIELDS="id"/>
        <KEY NAME="aaleid"  TYPE="foreign" FIELDS="aaleid"  REFTABLE="aale"       REFFIELDS="id"/>
        <KEY NAME="userid"  TYPE="foreign" FIELDS="userid"  REFTABLE="user"       REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="slotid_userid" UNIQUE="true" FIELDS="slotid, userid"
               COMMENT="One booking per student per slot (no duplicate bookings)"/>
        <INDEX NAME="aaleid_userid" UNIQUE="false" FIELDS="aaleid, userid"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         CLASS MODE — Attendance records.
         session_number ranges 1 – att_sessions (max 20).
         Faculty marks Present/Absent; can freeze each session column.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_attendance" COMMENT="Class-mode attendance — per booking per session column">
      <FIELDS>
        <FIELD NAME="id"             TYPE="int" LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="bookingid"      TYPE="int" LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="FK → aale_bookings.id"/>
        <FIELD NAME="session_number" TYPE="int" LENGTH="4"  NOTNULL="true"  DEFAULT="1"
               COMMENT="Session column number 1 – 20 (matches att_sessions count on the slot)"/>
        <FIELD NAME="present"        TYPE="int" LENGTH="2"  NOTNULL="true"  DEFAULT="0"
               COMMENT="0 = Absent, 1 = Present"/>
        <FIELD NAME="frozen"         TYPE="int" LENGTH="2"  NOTNULL="true"  DEFAULT="0"
               COMMENT="1 = session attendance frozen by faculty (no further edits)"/>
        <FIELD NAME="markedby"       TYPE="int" LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="frozenby"       TYPE="int" LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="frozenat"       TYPE="int" LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated"    TYPE="int" LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"   TYPE="int" LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"   TYPE="primary" FIELDS="id"/>
        <KEY NAME="bookingid" TYPE="foreign" FIELDS="bookingid" REFTABLE="aale_bookings" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="bookingid_session" UNIQUE="true" FIELDS="bookingid, session_number"
               COMMENT="One attendance record per booking per session column"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         CPA MODE — Assessment outcomes per student booking.
         Outcomes: W1 (pass) | try_again | small_practice
         Assessment triggers ONLY after faculty marks student Present.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_outcomes" COMMENT="CPA-mode assessment outcomes per booking">
      <FIELDS>
        <FIELD NAME="id"             TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="bookingid"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="FK → aale_bookings.id"/>
        <FIELD NAME="outcome"        TYPE="char" LENGTH="20" NOTNULL="true"  DEFAULT=""
               COMMENT="W1 (pass) | try_again | small_practice"/>
        <FIELD NAME="prev_outcome"   TYPE="char" LENGTH="20" NOTNULL="true"  DEFAULT=""
               COMMENT="Previous outcome value (audit trail for overrides)"/>
        <FIELD NAME="notes"          TYPE="text"             NOTNULL="false"
               COMMENT="Faculty notes or admin override reason"/>
        <FIELD NAME="assessment_triggered" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0"
               COMMENT="1 = assessment was triggered after attendance mark (Present)"/>
        <FIELD NAME="assessment_triggered_at" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
               COMMENT="Unix TS when assessment was triggered"/>
        <FIELD NAME="coins_awarded"  TYPE="int"  LENGTH="6"  NOTNULL="true"  DEFAULT="0"
               COMMENT="Coins awarded on W1 outcome for this booking"/>
        <FIELD NAME="setat"          TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="freezeat"       TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Unix TS when outcome auto-freezes (setat + 1800s)"/>
        <FIELD NAME="markedby"       TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="frozen"         TYPE="int"  LENGTH="2"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="admin_override" TYPE="int"  LENGTH="2"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="overrideby"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="overrideat"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated"    TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"   TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"   TYPE="primary" FIELDS="id"/>
        <KEY NAME="bookingid" TYPE="foreign" FIELDS="bookingid" REFTABLE="aale_bookings" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="bookingid"     UNIQUE="true"  FIELDS="bookingid"/>
        <INDEX NAME="frozen_freeze" UNIQUE="false" FIELDS="frozen, freezeat"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         Reward coins ledger (immutable transaction log).
         Coins are reward points only — no monetary value.
         Awarded on W1 (pass) outcome.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_coins" COMMENT="Reward coins transaction ledger (immutable)">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="aaleid"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="userid"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="bookingid"   TYPE="int"  LENGTH="10" NOTNULL="false"
               COMMENT="NULL for manual admin transactions"/>
        <FIELD NAME="amount"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Positive = earned, negative = deducted"/>
        <FIELD NAME="balance"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Running balance at time of this transaction"/>
        <FIELD NAME="txtype"      TYPE="char" LENGTH="24" NOTNULL="true"  DEFAULT=""
               COMMENT="assessment_w1 | redemption | admin_add | admin_deduct"/>
        <FIELD NAME="notes"       TYPE="text"             NOTNULL="false"/>
        <FIELD NAME="createdby"   TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="aaleid"  TYPE="foreign" FIELDS="aaleid" REFTABLE="aale" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_aaleid" UNIQUE="false" FIELDS="userid, aaleid"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         CPA question assignments — per student per booking.
         Questions randomly selected from question bank at attendance time.
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_qassign" COMMENT="Questions assigned to a student for a CPA booking">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="bookingid"    TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="cpaid"        TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"
               COMMENT="Linked CPA activity ID"/>
        <FIELD NAME="questionid"   TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="qtype"        TYPE="char" LENGTH="16" NOTNULL="true"  DEFAULT="coding"
               COMMENT="coding | mcq"/>
        <FIELD NAME="sortorder"    TYPE="int"  LENGTH="4"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"   TYPE="primary" FIELDS="id"/>
        <KEY NAME="bookingid" TYPE="foreign" FIELDS="bookingid" REFTABLE="aale_bookings" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="bookingid" UNIQUE="false" FIELDS="bookingid"/>
      </INDEXES>
    </TABLE>

    <!-- ══════════════════════════════════════════════════════════════════════
         Notification queue (email pending dispatch).
    ══════════════════════════════════════════════════════════════════════════ -->
    <TABLE NAME="aale_notifications" COMMENT="Pending email notification queue">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="bookingid"    TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="userid"       TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="type"         TYPE="char" LENGTH="32" NOTNULL="true"  DEFAULT=""
               COMMENT="booking_confirmed | outcome_w1 | outcome_try_again | reminder"/>
        <FIELD NAME="extra"        TYPE="text"             NOTNULL="false"
               COMMENT="JSON context data for email template"/>
        <FIELD NAME="status"       TYPE="char" LENGTH="16" NOTNULL="true"  DEFAULT="pending"
               COMMENT="pending | sent | failed"/>
        <FIELD NAME="attempts"     TYPE="int"  LENGTH="4"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timesent"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"   TYPE="primary" FIELDS="id"/>
        <KEY NAME="bookingid" TYPE="foreign" FIELDS="bookingid" REFTABLE="aale_bookings" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="status"    UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="bookingid" UNIQUE="false" FIELDS="bookingid"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
