{{! Theme Classic Modern — bare base layout (Moodle uses this for minimal/embedded pages) }}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <script>
        (function(){
            try {
                var t = localStorage.getItem('cm-theme');
                if (t !== 'light') document.documentElement.classList.add('dark');
            } catch(e) { document.documentElement.classList.add('dark'); }
        })();
    </script>
    <style>
        :root {
            --cm-bg: #f6f6f4; --cm-surface: #ffffff;
            --cm-text: #1a1a1a; --cm-muted: #6b7280;
            --cm-border: rgba(0,0,0,0.09); --cm-accent: #d97706;
            --cm-dot: rgba(0,0,0,0.055);
        }
        html.dark {
            --cm-bg: #111111; --cm-surface: #1a1a1a;
            --cm-text: #e8e6e1; --cm-muted: #78716c;
            --cm-border: rgba(255,255,255,0.08);
            --cm-dot: rgba(255,255,255,0.04);
        }
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: var(--cm-bg);
            color: var(--cm-text);
            background-image: radial-gradient(circle, var(--cm-dot) 1px, transparent 1px);
            background-size: 28px 28px;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }
        h1, h2, h3, h4 { font-family: 'Poppins', sans-serif; color: var(--cm-text); }
        p, span, div, li { color: var(--cm-text); }
        a { color: #93c5fd; }
        html:not(.dark) a { color: #1d4ed8; }
        .card, .generalbox, .box {
            background: var(--cm-surface) !important;
            border: 1px solid var(--cm-border) !important;
            border-radius: 10px !important;
            color: var(--cm-text) !important;
        }
    </style>
    {{{ output.standard_top_of_body_html_head }}}
</head>
<body {{{ bodyattributes }}}>
{{{ output.standard_top_of_body_html }}}
<div style="min-height:100vh;padding:1.5rem;max-width:1280px;margin:0 auto">
    {{{ maincontent }}}
</div>
{{{ output.standard_end_of_body_html }}}
</body>
</html>
