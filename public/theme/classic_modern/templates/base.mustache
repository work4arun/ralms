{{! Theme Classic Modern – bare base layout (used by Moodle for minimal pages) }}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <script>
        (function(){
            var t=localStorage.getItem('cm-theme');
            if(t!=='light') document.documentElement.classList.add('dark');
        })();
    </script>
    <style>
        :root { --cm-bg:#f5f5f5; --cm-text:#1a1a1a; --cm-dot:rgba(0,0,0,0.07); }
        html.dark { --cm-bg:#131313; --cm-text:#e2e8f0; --cm-dot:rgba(255,255,255,0.055); }
        body {
            font-family: system-ui, sans-serif;
            background-color: var(--cm-bg);
            color: var(--cm-text);
            background-image: radial-gradient(circle, var(--cm-dot) 1px, transparent 1px);
            background-size: 28px 28px;
            min-height: 100vh;
        }
        p, span, div, h1, h2, h3, h4, h5, h6 { color: var(--cm-text); }
    </style>
    {{{ output.standard_top_of_body_html_head }}}
</head>
<body {{{ bodyattributes }}}>
{{{ output.standard_top_of_body_html }}}
<div style="min-height:100vh;padding:1.5rem">
    {{{ output.main_content }}}
</div>
{{{ output.standard_end_of_body_html }}}
</body>
</html>
