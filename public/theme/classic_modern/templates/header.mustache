{{!
    @template theme_classic_modern/header

    Sticky header / navbar. Claude-inspired dark theme.
    Uses CSS variables from standard.mustache for colors.

    Context variables:
    * sitename  - Site short name
    * output    - Core renderer
    * usermenu  - User menu HTML
    * langmenu  - Language menu export
}}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div style="display:flex;align-items:center;justify-content:space-between;height:56px;gap:1rem">

        {{! ── Brand / Logo ── }}
        <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
            <a href="{{{ config.wwwroot }}}" class="site-name" style="display:flex;align-items:center;gap:8px;text-decoration:none">
                {{#output.get_compact_logo_url}}
                    <img src="{{{ output.get_compact_logo_url }}}"
                         alt="{{{ sitename }}}"
                         style="height:28px;width:auto">
                {{/output.get_compact_logo_url}}
                {{^output.get_compact_logo_url}}
                    <svg style="width:22px;height:22px;flex-shrink:0" viewBox="0 0 24 24" fill="none">
                        <rect width="24" height="24" rx="6" fill="#d97706"/>
                        <path d="M7 12h10M12 7v10" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/>
                    </svg>
                    <span class="site-name">{{sitename}}</span>
                {{/output.get_compact_logo_url}}
            </a>
        </div>

        {{! ── Right actions ── }}
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0">

            {{! Dark / Light toggle }}
            <button id="cm-theme-toggle"
                    title="Toggle dark / light mode"
                    aria-label="Toggle dark/light mode">
                {{! Moon icon — visible in LIGHT mode }}
                <svg class="icon-light" style="width:16px;height:16px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
                </svg>
                {{! Sun icon — visible in DARK mode }}
                <svg class="icon-dark" style="width:16px;height:16px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="5"/>
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42
                             M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                </svg>
                <span class="icon-dark" style="display:none">Light</span>
                <span class="icon-light">Dark</span>
            </button>

            {{! Language menu }}
            {{#langmenu}}
                <div style="font-size:0.875rem">{{> core/action_menu}}</div>
            {{/langmenu}}

            {{! User menu }}
            {{#usermenu}}
                <div style="font-size:0.875rem">{{{ usermenu }}}</div>
            {{/usermenu}}

        </div>
    </div>
</div>
