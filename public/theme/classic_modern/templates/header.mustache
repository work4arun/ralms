{{!
    @template theme_classic_modern/header

    Sticky header for Classic Modern theme.
    Includes: site logo/name, user menu, language menu, dark/light toggle.

    Context variables:
    * sitename  – Site short name
    * output    – Core renderer
    * usermenu  – User menu HTML
    * langmenu  – Language menu export
    * config    – Moodle config (wwwroot etc.)
}}
<div style="width:100%;max-width:1280px;margin:0 auto;
            padding:0 1.25rem;
            display:flex;align-items:center;justify-content:space-between;
            height:60px;gap:1rem">

    {{! ── Brand / Logo ── }}
    <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
        <a href="{{{ config.wwwroot }}}" class="site-name"
           style="display:flex;align-items:center;gap:8px;text-decoration:none"
           title="Home">

            {{#output.get_compact_logo_url}}
                <img src="{{{ output.get_compact_logo_url }}}"
                     alt="{{{ sitename }}}"
                     style="height:32px;width:auto;object-fit:contain">
            {{/output.get_compact_logo_url}}

            {{^output.get_compact_logo_url}}
                {{! Default logo mark — amber rounded square with cross ──── }}
                <span style="display:flex;align-items:center;justify-content:center;
                             width:32px;height:32px;border-radius:8px;flex-shrink:0;
                             background:linear-gradient(135deg,#d97706,#f59e0b)">
                    <svg style="width:16px;height:16px" viewBox="0 0 24 24" fill="none">
                        <path d="M7 12h10M12 7v10" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                </span>
                <span class="site-name">{{sitename}}</span>
            {{/output.get_compact_logo_url}}
        </a>
    </div>

    {{! ── Keyboard shortcut hint (hidden on mobile, subtle reminder) ── }}
    <div style="flex:1;display:flex;align-items:center;justify-content:center">
        <span style="font-size:0.7rem;color:var(--cm-muted);display:none"
              class="cm-kbd-hint">
            Press <kbd style="font-family:monospace;padding:1px 5px;border-radius:3px;
                              border:1px solid var(--cm-border);font-size:0.7rem">F</kbd>
            for focus mode &nbsp;·&nbsp;
            <kbd style="font-family:monospace;padding:1px 5px;border-radius:3px;
                        border:1px solid var(--cm-border);font-size:0.7rem">D</kbd>
            for dark mode
        </span>
    </div>

    {{! ── Right actions ── }}
    <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">

        {{! Dark / Light toggle }}
        <button id="cm-theme-toggle"
                title="Toggle dark/light mode (keyboard: D)"
                aria-label="Toggle dark/light mode">
            {{! Moon — shown in light mode }}
            <svg class="icon-light" style="width:15px;height:15px;flex-shrink:0" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
            </svg>
            {{! Sun — shown in dark mode }}
            <svg class="icon-dark" style="width:15px;height:15px;flex-shrink:0" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5"/>
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42
                         M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
            </svg>
            <span class="icon-light" style="font-size:0.8rem">Dark</span>
            <span class="icon-dark"  style="font-size:0.8rem;display:none">Light</span>
        </button>

        {{! Language menu }}
        {{#langmenu}}
            <div style="font-size:0.875rem">{{> core/action_menu}}</div>
        {{/langmenu}}

        {{! User menu }}
        {{#usermenu}}
            <div style="font-size:0.875rem">{{{ usermenu }}}</div>
        {{/usermenu}}

    </div>
</div>

<style>
    /* Show keyboard hint on desktop */
    @media (min-width: 1024px) {
        .cm-kbd-hint { display: inline !important; }
    }
</style>
