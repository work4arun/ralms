{{!
    Theme Classic Modern – login page.
    Modern split-screen design with gradient hero and glass card.
}}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}

    {{! Tailwind CSS }}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#3B82F6',
                        accent:  '#8B5CF6'
                    }
                }
            }
        }
    </script>

    {{! Google Fonts }}
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap">

    <style>
        body { font-family: 'Inter', system-ui, sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Poppins', sans-serif; }
    </style>

    {{{ output.standard_top_of_body_html_head }}}
</head>

<body {{{ bodyattributes }}} class="bg-gradient-to-br from-blue-50 via-purple-50 to-blue-100 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
{{{ output.standard_top_of_body_html }}}

<div class="min-h-screen flex">

    {{! Left panel — hero (hidden on mobile) }}
    <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-blue-600 to-purple-600 flex-col justify-between p-12 relative overflow-hidden">

        {{! Decorative blobs }}
        <div class="absolute top-0 right-0 w-96 h-96 bg-white opacity-10 rounded-full -mr-48 -mt-48"></div>
        <div class="absolute bottom-0 left-0 w-80 h-80 bg-blue-400 opacity-20 rounded-full -ml-40 -mb-40"></div>

        <div class="relative z-10">
            <h1 class="text-5xl font-bold text-white mb-4">Welcome to {{sitename}}</h1>
            <p class="text-blue-100 text-lg leading-relaxed max-w-md">
                A modern learning platform designed for collaboration, engagement, and success. Sign in to continue your journey.
            </p>
        </div>

        <div class="relative z-10 space-y-4">
            <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-200 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></path></svg>
                <p class="text-blue-100">Fast, intuitive course experience</p>
            </div>
            <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-200 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></path></svg>
                <p class="text-blue-100">Responsive design on all devices</p>
            </div>
            <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-blue-200 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></path></svg>
                <p class="text-blue-100">Built with modern web standards</p>
            </div>
        </div>
    </div>

    {{! Right panel — login card }}
    <div class="flex-1 flex items-center justify-center p-4 lg:w-1/2">
        <div class="w-full max-w-md">

            {{! Card }}
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-8 backdrop-blur-xl bg-opacity-95">

                {{! Header }}
                <div class="text-center mb-8">
                    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Sign In</h2>
                    <p class="text-gray-600 dark:text-gray-400">Enter your credentials to continue</p>
                </div>

                {{! Language menu }}
                {{#langmenu}}
                    <div class="mb-6 pb-6 border-b border-gray-200 dark:border-gray-700">
                        {{> core/action_menu}}
                    </div>
                {{/langmenu}}

                {{! Login form (injected by Moodle) }}
                <div class="space-y-4">
                    {{{ output.main_content }}}
                </div>

            </div>

            {{! Footer link }}
            <p class="text-center text-sm text-gray-600 dark:text-gray-400 mt-6">
                Having trouble? <a href="#" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">Contact support</a>
            </p>

        </div>
    </div>

</div>

{{! Dark mode toggle (top right) }}
<button id="cm-darkmode-toggle" class="fixed top-4 right-4 p-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-lg hover:shadow-xl transition z-50"
        aria-label="Toggle dark mode">
    <svg class="w-5 h-5 text-gray-600 dark:hidden" fill="currentColor" viewBox="0 0 20 20">
        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
    </svg>
    <svg class="w-5 h-5 text-yellow-500 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.536l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.121-10.071l.707-.707a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 103.636 5.05l-.707.707a1 1 0 001.414 1.414l.707-.707zm5.414 5.414a1 1 0 01-1.414 0L7.05 10.364a1 1 0 011.414-1.414l2.121 2.121zM5 8a1 1 0 100-2H4a1 1 0 100 2h1z" clip-rule="evenodd"></path>
    </svg>
</button>

{{{ output.standard_after_main_region_html }}}
{{{ output.standard_end_of_body_html }}}

<script>
    document.getElementById('cm-darkmode-toggle').addEventListener('click', function() {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('cm-dark-mode', document.documentElement.classList.contains('dark'));
    });
    if (localStorage.getItem('cm-dark-mode') === 'true' || (!localStorage.getItem('cm-dark-mode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
    }
</script>

</body>
</html>
