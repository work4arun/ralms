{{!
    Theme Classic Modern — Cobalt Professional Login Page
    Animated hero background, floating orbs, split-panel, blue gradient system.
    Dark by default, toggleable.
}}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>

    {{! Anti-FOUC }}
    <script>
        (function () {
            try {
                var t = localStorage.getItem('cm-theme');
                if (t === 'light') document.documentElement.classList.remove('dark');
                else document.documentElement.classList.add('dark');
            } catch(e) { document.documentElement.classList.add('dark'); }
        })();
    </script>

    <style>
        /* ── Variables ── */
        :root {
            --bg:       #f0f4ff;
            --surface:  #ffffff;
            --shi:      #e8effe;
            --border:   rgba(37,99,235,0.14);
            --bstr:     rgba(37,99,235,0.3);
            --text:     #0f172a;
            --sub:      #334155;
            --muted:    #64748b;
            --accent:   #2563eb;
            --glow:     rgba(59,130,246,0.35);
            --dot:      rgba(37,99,235,0.07);
            --grad:     linear-gradient(135deg, #2563eb 0%, #6366f1 100%);
            --hero:     linear-gradient(160deg, #0d1a3a 0%, #1e3a8a 45%, #0d1a3a 100%);
        }
        html.dark {
            --bg:      #060b18;
            --surface: #0d1424;
            --shi:     #141d32;
            --border:  rgba(96,165,250,0.12);
            --bstr:    rgba(96,165,250,0.28);
            --text:    #e2e8f0;
            --sub:     #94a3b8;
            --muted:   #475569;
            --accent:  #60a5fa;
            --glow:    rgba(96,165,250,0.3);
            --dot:     rgba(96,165,250,0.05);
        }

        /* ── Base ── */
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }
        h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', sans-serif; color: var(--text); }
        a { color: var(--accent); text-decoration: none; }
        a:hover { opacity: 0.85; text-decoration: underline; }
        p, span, label, li { color: var(--text); }

        /* ── Keyframes ── */
        @keyframes orb-drift-1 {
            0%,100% { transform: translate(0,0) scale(1); }
            33%      { transform: translate(40px,-30px) scale(1.08); }
            66%      { transform: translate(-20px,20px) scale(0.95); }
        }
        @keyframes orb-drift-2 {
            0%,100% { transform: translate(0,0) scale(1); }
            33%      { transform: translate(-50px,40px) scale(1.12); }
            66%      { transform: translate(30px,-20px) scale(0.92); }
        }
        @keyframes orb-drift-3 {
            0%,100% { transform: translate(0,0) scale(1); }
            50%      { transform: translate(20px,-50px) scale(1.06); }
        }
        @keyframes fade-up {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes float {
            0%,100% { transform: translateY(0); }
            50%      { transform: translateY(-10px); }
        }
        @keyframes grid-scroll {
            from { background-position: 0 0; }
            to   { background-position: 0 40px; }
        }
        @keyframes shimmer-grad {
            0%   { background-position: 0% 50%; }
            50%  { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        @keyframes slide-in-right {
            from { opacity: 0; transform: translateX(24px); }
            to   { opacity: 1; transform: translateX(0); }
        }

        /* ── Page layout ── */
        .cm-login-page {
            min-height: 100vh;
            display: flex;
        }

        /* ── Hero panel (left) ── */
        .cm-hero {
            display: none;
            flex: 1;
            position: relative;
            overflow: hidden;
            background: var(--hero);
        }
        @media (min-width: 900px) { .cm-hero { display: block; } }

        /* Animated dot grid overlay */
        .cm-hero-grid {
            position: absolute; inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
            background-size: 28px 28px;
            animation: grid-scroll 8s linear infinite;
        }

        /* Floating orbs */
        .cm-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            pointer-events: none;
        }
        .cm-orb-1 {
            width: 380px; height: 380px;
            top: -80px; left: -80px;
            background: radial-gradient(circle, rgba(59,130,246,0.45), transparent 70%);
            animation: orb-drift-1 12s ease-in-out infinite;
        }
        .cm-orb-2 {
            width: 300px; height: 300px;
            bottom: -60px; right: -60px;
            background: radial-gradient(circle, rgba(99,102,241,0.5), transparent 70%);
            animation: orb-drift-2 15s ease-in-out infinite;
        }
        .cm-orb-3 {
            width: 220px; height: 220px;
            top: 40%; left: 50%;
            background: radial-gradient(circle, rgba(34,211,238,0.3), transparent 70%);
            animation: orb-drift-3 10s ease-in-out infinite;
        }

        /* Hero content */
        .cm-hero-content {
            position: relative; z-index: 1;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 3rem;
        }

        .cm-hero-logo {
            display: flex; align-items: center; gap: 10px;
            animation: fade-up 0.6s ease both;
        }
        .cm-hero-logo-mark {
            width: 40px; height: 40px; border-radius: 12px;
            background: linear-gradient(135deg,#2563eb,#6366f1);
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 20px rgba(59,130,246,0.5);
            animation: float 4s ease-in-out infinite;
        }
        .cm-hero-logo span {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 800; font-size: 1.1rem; color: #fff;
            letter-spacing: -0.03em;
        }

        .cm-hero-main { animation: fade-up 0.6s 0.1s ease both; }
        .cm-hero-main h1 {
            font-size: 2.5rem; font-weight: 800; line-height: 1.1;
            letter-spacing: -0.04em; margin: 0 0 1rem;
            background: linear-gradient(135deg, #fff 30%, #93c5fd 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .cm-hero-main p {
            color: rgba(255,255,255,0.62) !important;
            font-size: 0.95rem; line-height: 1.7;
            max-width: 340px; margin: 0;
        }

        /* Feature list */
        .cm-features { animation: fade-up 0.6s 0.2s ease both; }
        .cm-feat {
            display: flex; gap: 1rem; align-items: flex-start;
            margin-bottom: 1.25rem;
        }
        .cm-feat-icon {
            width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem;
            backdrop-filter: blur(8px);
            transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
        }
        .cm-feat:hover .cm-feat-icon { transform: scale(1.12) rotate(-5deg); }
        .cm-feat-text strong {
            display: block; font-size: 0.9rem; font-weight: 700;
            color: #e2e8f0; margin-bottom: 0.2rem; letter-spacing: -0.01em;
        }
        .cm-feat-text span {
            display: block; font-size: 0.8rem; color: rgba(255,255,255,0.55) !important;
            line-height: 1.55;
        }

        .cm-hero-footer {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.3) !important;
            animation: fade-up 0.6s 0.3s ease both;
        }

        /* ── Stats bar ── */
        .cm-stats {
            display: flex; gap: 2rem;
            margin: 1.75rem 0;
            animation: fade-up 0.6s 0.15s ease both;
        }
        .cm-stat-val {
            font-size: 1.6rem; font-weight: 800;
            background: linear-gradient(135deg,#60a5fa,#a5b4fc);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text; line-height: 1;
        }
        .cm-stat-label {
            font-size: 0.72rem; color: rgba(255,255,255,0.45) !important;
            font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase;
        }

        /* ── Form panel (right) ── */
        .cm-form-panel {
            width: 100%;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 2.5rem 2rem;
            background: var(--surface);
            min-height: 100vh;
            position: relative;
            overflow: hidden;
        }
        @media (min-width: 900px) { .cm-form-panel { width: 460px; flex-shrink: 0; } }

        /* Subtle gradient overlay on form panel */
        .cm-form-panel::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 4px;
            background: linear-gradient(90deg, #2563eb, #6366f1, #06b6d4);
            background-size: 200% auto;
            animation: shimmer-grad 4s linear infinite;
        }

        /* Form inner */
        .cm-form-inner {
            width: 100%; max-width: 370px;
            animation: slide-in-right 0.5s cubic-bezier(0.22,1,0.36,1) both;
        }

        /* Logo mark (mobile only) */
        .cm-card-logo {
            width: 52px; height: 52px; border-radius: 16px;
            background: linear-gradient(135deg,#2563eb,#6366f1);
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.75rem;
            box-shadow: 0 8px 24px rgba(59,130,246,0.35);
        }

        /* Moodle form overrides */
        input[type="text"], input[type="email"], input[type="password"],
        input[type="search"], select, textarea, .form-control {
            background: var(--shi) !important;
            color: var(--text) !important;
            border: 1.5px solid var(--border) !important;
            border-radius: 10px !important;
            padding: 0.7rem 1rem !important;
            font-size: 0.9rem !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            width: 100%;
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        }
        input:focus, .form-control:focus {
            border-color: var(--accent) !important;
            box-shadow: 0 0 0 3px var(--glow) !important;
            outline: none !important;
            background: var(--surface) !important;
        }
        input::placeholder { color: var(--muted) !important; }
        label, .col-form-label {
            color: var(--text) !important;
            font-weight: 600 !important; font-size: 0.85rem !important;
            display: block; margin-bottom: 0.35rem; letter-spacing: -0.01em;
        }
        .form-text, .help-block { color: var(--muted) !important; font-size: 0.78rem; margin-top: 0.25rem; }
        .form-group { margin-bottom: 1.15rem; }

        .btn-primary, input[type="submit"], button[type="submit"] {
            background: linear-gradient(135deg,#2563eb,#6366f1) !important;
            border: none !important;
            color: #fff !important;
            font-weight: 700 !important;
            border-radius: 10px !important;
            padding: 0.75rem 1.75rem !important;
            font-size: 0.95rem !important;
            width: 100%; cursor: pointer;
            box-shadow: 0 4px 16px rgba(59,130,246,0.35) !important;
            transition: all 0.2s ease !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            letter-spacing: -0.01em !important;
        }
        .btn-primary:hover, input[type="submit"]:hover, button[type="submit"]:hover {
            transform: translateY(-2px) !important;
            box-shadow: 0 8px 28px rgba(59,130,246,0.45) !important;
            filter: brightness(1.08) !important;
        }
        .btn-secondary {
            background: var(--shi) !important;
            border: 1.5px solid var(--bstr) !important;
            color: var(--text) !important;
            border-radius: 10px !important;
        }
        .alert {
            background: var(--shi) !important;
            color: var(--text) !important;
            border: 1.5px solid var(--border) !important;
            border-radius: 10px !important;
            padding: 0.875rem 1rem;
            font-size: 0.875rem;
            margin-bottom: 1rem;
        }
        .alert-danger  { border-left: 4px solid #ef4444 !important; background: rgba(239,68,68,0.06) !important; }
        .alert-success { border-left: 4px solid #10b981 !important; background: rgba(16,185,129,0.06) !important; }
        .alert-info    { border-left: 4px solid #3b82f6 !important; background: rgba(59,130,246,0.06) !important; }

        /* Divider */
        .cm-divider {
            display: flex; align-items: center; gap: 0.75rem;
            margin: 1.5rem 0;
        }
        .cm-divider::before, .cm-divider::after {
            content: ''; flex: 1; border-top: 1px solid var(--border);
        }
        .cm-divider span { color: var(--muted); font-size: 0.75rem; white-space: nowrap; }

        /* Theme toggle (fixed) */
        #cm-theme-toggle {
            position: fixed; top: 1rem; right: 1rem;
            display: flex; align-items: center; gap: 6px;
            padding: 7px 13px;
            border-radius: 10px;
            border: 1.5px solid var(--border);
            background: var(--surface);
            color: var(--text);
            font-size: 0.8rem; font-weight: 600;
            cursor: pointer; z-index: 200;
            box-shadow: 0 4px 16px rgba(37,99,235,0.12);
            transition: all 0.2s ease;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        #cm-theme-toggle:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(59,130,246,0.07);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(59,130,246,0.2);
        }
        #cm-theme-toggle .icon-dark  { display: none; }
        #cm-theme-toggle .icon-light { display: inline-flex; }
        html.dark #cm-theme-toggle .icon-dark  { display: inline-flex; }
        html.dark #cm-theme-toggle .icon-light { display: none; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 7px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--bstr); border-radius: 999px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent); }
        :focus-visible { outline: 2px solid var(--accent) !important; outline-offset: 2px; border-radius: 4px; }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
        }
    </style>

    {{{ output.standard_top_of_body_html_head }}}
</head>

<body {{{ bodyattributes }}}>
{{{ output.standard_top_of_body_html }}}

{{! ── Dark / Light toggle ── }}
<button id="cm-theme-toggle" aria-label="Toggle dark/light mode">
    <svg class="icon-light" style="width:14px;height:14px" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
    </svg>
    <svg class="icon-dark" style="width:14px;height:14px" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/>
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42
                 M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <span class="icon-light">Dark</span>
    <span class="icon-dark" style="display:none">Light</span>
</button>

<div class="cm-login-page">

    {{! ══════════════════════════════════
        LEFT — Animated Hero Panel
    ══════════════════════════════════ }}
    <div class="cm-hero">
        <div class="cm-hero-grid"></div>
        <div class="cm-orb cm-orb-1"></div>
        <div class="cm-orb cm-orb-2"></div>
        <div class="cm-orb cm-orb-3"></div>

        <div class="cm-hero-content">

            {{! Brand }}
            <div class="cm-hero-logo">
                <div class="cm-hero-logo-mark">
                    <svg style="width:20px;height:20px" viewBox="0 0 24 24" fill="none">
                        <path d="M12 3L4 9v12h16V9L12 3z" stroke="#fff" stroke-width="2" stroke-linejoin="round"/>
                        <path d="M9 21v-8h6v8" stroke="#fff" stroke-width="2" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span>{{sitename}}</span>
            </div>

            {{! Headline }}
            <div class="cm-hero-main">
                <h1>Learn smarter,<br>not harder.</h1>
                <p>A focused, beautiful learning environment designed to help you achieve your goals with clarity and confidence.</p>

                {{! Stats }}
                <div class="cm-stats">
                    <div>
                        <div class="cm-stat-val">100%</div>
                        <div class="cm-stat-label">Progress Tracking</div>
                    </div>
                    <div>
                        <div class="cm-stat-val">∞</div>
                        <div class="cm-stat-label">Resources</div>
                    </div>
                    <div>
                        <div class="cm-stat-val">24/7</div>
                        <div class="cm-stat-label">Access</div>
                    </div>
                </div>
            </div>

            {{! Feature list }}
            <div class="cm-features">
                <div class="cm-feat">
                    <div class="cm-feat-icon" style="background:rgba(59,130,246,0.18)">📚</div>
                    <div class="cm-feat-text">
                        <strong>Course Library</strong>
                        <span>All your courses, materials, and resources in one organised space.</span>
                    </div>
                </div>
                <div class="cm-feat">
                    <div class="cm-feat-icon" style="background:rgba(16,185,129,0.15)">📈</div>
                    <div class="cm-feat-text">
                        <strong>Progress Tracking</strong>
                        <span>Visual completion indicators so you always know where you stand.</span>
                    </div>
                </div>
                <div class="cm-feat">
                    <div class="cm-feat-icon" style="background:rgba(139,92,246,0.15)">🎯</div>
                    <div class="cm-feat-text">
                        <strong>Focus Mode</strong>
                        <span>Distraction-free reading view for deep, concentrated learning.</span>
                    </div>
                </div>
            </div>

            <p class="cm-hero-footer">Classic Modern Theme · Moodle LMS</p>
        </div>
    </div>

    {{! ══════════════════════════════════
        RIGHT — Login Form
    ══════════════════════════════════ }}
    <div class="cm-form-panel">
        <div class="cm-form-inner">

            {{! Logo mark (visible on mobile) }}
            <div class="cm-card-logo">
                <svg style="width:26px;height:26px" viewBox="0 0 24 24" fill="none">
                    <path d="M12 3L4 9v12h16V9L12 3z" stroke="#fff" stroke-width="2" stroke-linejoin="round"/>
                    <path d="M9 21v-8h6v8" stroke="#fff" stroke-width="2" stroke-linejoin="round"/>
                </svg>
            </div>

            <div style="margin-bottom:2rem">
                <h1 style="font-size:1.6rem;font-weight:800;margin:0 0 0.3rem;
                           letter-spacing:-0.03em;line-height:1.1">
                    Welcome back
                </h1>
                <p style="font-size:0.875rem;color:var(--muted);margin:0">
                    Sign in to continue to <strong style="color:var(--accent)">{{sitename}}</strong>
                </p>
            </div>

            {{! Language menu }}
            {{#langmenu}}
                <div style="margin-bottom:1.25rem;padding-bottom:1.25rem;
                            border-bottom:1px solid var(--border)">
                    {{> core/action_menu}}
                </div>
            {{/langmenu}}

            {{! Moodle injects login form here }}
            <div>
                {{{ output.main_content }}}
            </div>

            <div class="cm-divider"><span>New here?</span></div>

            <p style="text-align:center;font-size:0.8rem;color:var(--muted)">
                Contact your administrator or
                <a href="{{{ config.wwwroot }}}/login/signup.php"
                   style="color:var(--accent);font-weight:700">
                    create an account →
                </a>
            </p>

        </div>
    </div>

</div>

{{{ output.standard_after_main_region_html }}}
{{{ output.standard_end_of_body_html }}}

<script>
    document.getElementById('cm-theme-toggle').addEventListener('click', function () {
        var dark = document.documentElement.classList.toggle('dark');
        try { localStorage.setItem('cm-theme', dark ? 'dark' : 'light'); } catch(e){}
    });
</script>

</body>
</html>
