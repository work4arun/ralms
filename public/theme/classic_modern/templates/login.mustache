{{!
    Theme Classic Modern — Simple & Professional Login Page
    A clean, minimal interface focusing on the core essentials.
}}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #0f172a;
            --accent: {{brandcolor}};
            --bg-light: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --input-bg: #f8fafc;
            --radius: 12px;
        }

        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-light);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
        }

        .login-page-wrapper {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* Left Panel - Branding */
        .login-branding {
            flex: 1.2;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 6rem;
            color: white;
            position: relative;
            overflow: hidden;
        }

        @media (max-width: 900px) {
            .login-branding {
                display: none;
            }
        }

        .login-branding::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(37, 99, 235, 0.2) 0%, transparent 70%),
                        radial-gradient(circle at 80% 80%, rgba(37, 99, 235, 0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        .branding-content {
            position: relative;
            z-index: 10;
        }

        .branding-logo {
            font-size: 2.5rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            margin-bottom: 1.5rem;
            background: linear-gradient(to right, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .branding-tagline {
            font-size: 1.25rem;
            color: #94a3b8;
            max-width: 400px;
            line-height: 1.6;
            font-weight: 400;
        }

        /* Right Panel - Form */
        .login-form-area {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            padding: 2rem;
        }

        .login-card {
            width: 100%;
            max-width: 480px;
            padding: 1rem;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .card-header {
            margin-bottom: 2.5rem;
        }

        .card-header .login-logo {
            max-height: 60px;
            width: auto;
            margin-bottom: 1.5rem;
        }

        .card-header h2 {
            font-size: 1.875rem;
            font-weight: 700;
            color: var(--primary);
            margin: 0;
            letter-spacing: -0.02em;
        }

        .card-header p {
            color: var(--text-muted);
            margin-top: 0.5rem;
            font-size: 0.95rem;
        }

        /* Moodle Form Overrides */
        #loginform {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .form-control {
            border: 1.5px solid var(--border) !important;
            border-radius: var(--radius) !important;
            padding: 0.875rem 1.125rem !important;
            background-color: var(--input-bg) !important;
            font-size: 1rem !important;
            transition: all 0.2s ease !important;
            height: auto !important;
            margin-bottom: 0 !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

        .form-control:focus {
            border-color: var(--accent) !important;
            background-color: white !important;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1) !important;
            outline: none !important;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .btn-primary, input[type="submit"] {
            width: 100% !important;
            background: var(--primary) !important;
            border: none !important;
            border-radius: var(--radius) !important;
            padding: 1rem !important;
            font-weight: 700 !important;
            font-size: 1rem !important;
            color: white !important;
            cursor: pointer !important;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
            margin-top: 1rem !important;
        }

        .btn-primary:hover, input[type="submit"]:hover {
            background: #000 !important;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        /* Errors and Alerts */
        .alert {
            border-radius: var(--radius) !important;
            padding: 1rem !important;
            font-size: 0.9rem !important;
            margin-bottom: 1.5rem !important;
            border: none !important;
            display: flex;
            align-items: center;
        }

        .alert-danger {
            background-color: #fee2e2 !important;
            color: #991b1b !important;
        }

        /* Hide noise */
        .login-instructions, .login-divider, .login-identityprovider, 
        .login-guest, .login-signup, .login-footer-links, .forgetpass, .signup {
            display: none !important;
        }

        .langmenu {
            position: absolute;
            top: 2rem;
            right: 2rem;
        }
    </style>

    {{{ output.standard_top_of_body_html_head }}}
</head>

<body {{{ bodyattributes }}}>
{{{ output.standard_top_of_body_html }}}

<div class="login-page-wrapper">
    <div class="login-branding">
        <div class="branding-content">
            <div class="branding-logo">R-ACTIVE</div>
            <p class="branding-tagline">Experience a new standard of learning with the India's first industry-integrated LMS.</p>
        </div>
    </div>
    
    <div class="login-form-area">
        <div class="login-card">
            <div class="card-header">
                {{#logourl}}
                    <img src="{{{ logourl }}}" alt="{{sitename}}" class="login-logo">
                {{/logourl}}
                <h2>Welcome back</h2>
                <p>Please enter your details to sign in.</p>
            </div>

            <div class="login-form-wrapper">
                {{{ output.main_content }}}
            </div>
        </div>
    </div>
</div>

{{{ output.standard_after_main_region_html }}}
{{{ output.standard_end_of_body_html }}}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const usernameLabel = document.querySelector('label[for="username"]');
        const passwordLabel = document.querySelector('label[for="password"]');
        if (usernameLabel) usernameLabel.innerText = 'Username or Email';
        if (passwordLabel) passwordLabel.innerText = 'Password';
        
        const loginBtn = document.querySelector('#loginbtn');
        if (loginBtn) loginBtn.innerText = 'Sign In';
        
        // Remove 'Remember username' check if you want it cleaner, 
        // but it's usually better to keep for functionality.
    });
</script>
</body>
</html>
