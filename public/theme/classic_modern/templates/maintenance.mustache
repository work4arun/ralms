{{! Theme Classic Modern – maintenance page }}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>Maintenance</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' }</script>
    <script>(function(){ if(localStorage.getItem('cm-theme')!=='light') document.documentElement.classList.add('dark'); })();</script>
    <style>
        :root      { --cm-bg:#f5f5f5; --cm-surface:#fff;     --cm-border:rgba(0,0,0,0.1);   --cm-text:#1a1a1a; --cm-muted:#6b7280; --cm-dot:rgba(0,0,0,0.07); }
        html.dark  { --cm-bg:#131313; --cm-surface:#1e1e1e;  --cm-border:rgba(255,255,255,0.08); --cm-text:#e2e8f0; --cm-muted:#94a3b8; --cm-dot:rgba(255,255,255,0.055); }
        body {
            font-family: system-ui, sans-serif;
            background-color: var(--cm-bg);
            color: var(--cm-text);
            background-image: radial-gradient(circle, var(--cm-dot) 1px, transparent 1px);
            background-size: 28px 28px;
        }
        p, span, div { color: var(--cm-text); }
        h1 { font-size:1.5rem; font-weight:700; color:var(--cm-text); margin-bottom:0.75rem; }
    </style>
</head>
<body>
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:2rem">
    <div style="background:var(--cm-surface);border:1px solid var(--cm-border);border-radius:14px;padding:2.5rem;max-width:440px;width:100%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.3)">
        <div style="width:48px;height:48px;background:linear-gradient(135deg,#d97706,#f59e0b);border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem">
            <svg style="width:24px;height:24px" viewBox="0 0 24 24" fill="none">
                <path d="M12 9v4M12 17h.01" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/>
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <h1>Maintenance Mode</h1>
        <p style="color:var(--cm-muted);margin:0">The system is temporarily unavailable for scheduled maintenance. Please try again shortly.</p>
    </div>
</div>
</body>
</html>
