{{!
    Theme Classic Modern – standard layout template.
    Modern Tailwind-based two-column layout (main + sidebar).
}}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}

    {{! Tailwind CSS from CDN }}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#3B82F6',
                        accent:  '#8B5CF6'
                    }
                }
            }
        }
    </script>

    {{! Google Fonts }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap">

    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Poppins', sans-serif;
        }
    </style>

    {{{ output.standard_top_of_body_html_head }}}
</head>

<body {{{ bodyattributes }}}>
{{{ output.standard_top_of_body_html }}}

<div id="page" class="flex flex-col min-h-screen bg-white dark:bg-gray-950">

    {{! Header }}
    {{> theme_classic_modern/header }}

    {{! Main content area }}
    <div class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">

        {{! Breadcrumbs }}
        <div class="mb-6">
            {{{ output.navbar }}}
        </div>

        {{! Page heading }}
        {{#headercontent}}
            <div class="mb-8">
                {{> core/activity_header }}
            </div>
        {{/headercontent}}

        {{! Main content + sidebar }}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            {{! Main content (2/3 width) }}
            <main id="region-main" class="lg:col-span-2">
                {{{ output.main_content }}}
                {{{ output.activity_navigation }}}
            </main>

            {{! Sidebar (1/3 width) }}
            {{#hasblocks}}
                <aside id="block-region" class="lg:col-span-1">
                    <div class="space-y-6">
                        {{{ sidepreblocks }}}
                    </div>
                </aside>
            {{/hasblocks}}

        </div>
    </div>

    {{! Footer }}
    <footer class="mt-auto border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center text-sm text-gray-600 dark:text-gray-400">
                <span>{{{ sitename }}}</span>
                <div class="flex gap-6">
                    {{{ output.home_link }}}
                    {{{ output.login_info }}}
                </div>
            </div>
        </div>
    </footer>

</div>

{{{ output.standard_after_main_region_html }}}
{{{ output.standard_end_of_body_html }}}

<script>
    // Dark mode toggle
    document.getElementById('cm-darkmode-toggle').addEventListener('click', function() {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('cm-dark-mode', document.documentElement.classList.contains('dark'));
    });

    // Restore dark mode preference on load
    if (localStorage.getItem('cm-dark-mode') === 'true' || (!localStorage.getItem('cm-dark-mode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
    }
</script>

</body>
</html>
