{{!
    Theme Classic Modern — standard layout.
    Professional, learner-focused Moodle theme.
    Features: dark/light toggle, focus mode, reading progress bar,
              clean grid, learning-aware sidebar.
}}
<!DOCTYPE html>
<html {{{ bodyattributes }}}>
<head>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    {{{ output.standard_head_html }}}

    {{! ── Fonts ── }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap">

    {{! ── Tailwind CDN with darkMode:class ── }}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class' }
    </script>

    {{! ── Anti-FOUC: apply dark class BEFORE render ── }}
    <script>
        (function () {
            try {
                var t = localStorage.getItem('cm-theme');
                if (t === 'light') {
                    document.documentElement.classList.remove('dark');
                    document.documentElement.setAttribute('data-theme', 'light');
                } else {
                    document.documentElement.classList.add('dark');
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
                if (localStorage.getItem('cm-focus') === '1') {
                    document.body && document.body.classList.add('cm-focus-mode');
                }
            } catch (e) {
                document.documentElement.classList.add('dark');
            }
        })();
    </script>

    <style>
        /* ── CSS Variables (light defaults — dark overrides via html.dark) ── */
        :root {
            --cm-bg:           #f6f6f4;
            --cm-surface:      #ffffff;
            --cm-surface-hi:   #f0efec;
            --cm-surface-lo:   #fafaf8;
            --cm-border:       rgba(0,0,0,0.09);
            --cm-border-strong:rgba(0,0,0,0.18);
            --cm-text:         #1a1a1a;
            --cm-text-sub:     #4b5563;
            --cm-muted:        #6b7280;
            --cm-accent:       #d97706;
            --cm-accent-soft:  #fbbf24;
            --cm-accent-dark:  #b45309;
            --cm-link:         #1d4ed8;
            --cm-dot:          rgba(0,0,0,0.055);
            --cm-nav-h:        60px;
        }
        html.dark {
            --cm-bg:           #111111;
            --cm-surface:      #1a1a1a;
            --cm-surface-hi:   #222222;
            --cm-surface-lo:   #151515;
            --cm-border:       rgba(255,255,255,0.08);
            --cm-border-strong:rgba(255,255,255,0.18);
            --cm-text:         #e8e6e1;
            --cm-text-sub:     #a8a29e;
            --cm-muted:        #78716c;
            --cm-link:         #93c5fd;
            --cm-dot:          rgba(255,255,255,0.04);
        }

        /* ── Minimal layout glue (component styles live in modern.css) ── */
        *, *::before, *::after { box-sizing: border-box; }

        /* Moodle override — make everything transparent so our BG shows */
        #page, #page-wrapper, .pagelayout-standard, .pagelayout-course,
        .pagelayout-admin, [id^="page-"] {
            background: transparent !important;
            color: var(--cm-text) !important;
        }
        /* Remove Boost's own header */
        #page-header { background: transparent !important; }
    </style>

    {{{ output.standard_top_of_body_html_head }}}
</head>

<body {{{ bodyattributes }}}>
{{{ output.standard_top_of_body_html }}}

{{! ── Reading progress bar (fixed top) ── }}
<div id="cm-read-progress" aria-hidden="true"></div>

<div id="page" style="display:flex;flex-direction:column;min-height:100vh">

    {{! ══════════════════════════════════════
        STICKY HEADER
    ══════════════════════════════════════ }}
    <header id="cm-header">
        {{> theme_classic_modern/header }}
    </header>

    {{! ══════════════════════════════════════
        PAGE BODY
    ══════════════════════════════════════ }}
    <div style="flex:1;width:100%;max-width:1280px;margin:0 auto;padding:1.5rem 1.25rem 2rem">

        {{! ── Top bar: breadcrumb + page tools ── }}
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem">
            <nav aria-label="breadcrumb" style="font-size:0.8rem">
                {{{ output.navbar }}}
            </nav>

            {{! Focus mode toggle }}
            <button class="cm-focus-btn" id="cm-focus-toggle"
                    title="Focus mode — hides sidebars for distraction-free reading"
                    aria-label="Toggle focus mode"
                    aria-pressed="false">
                <svg style="width:14px;height:14px;flex-shrink:0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M15 3h6m0 0v6m0-6l-7 7M9 21H3m0 0v-6m0 6l7-7"/>
                </svg>
                <span id="cm-focus-label">Focus</span>
            </button>
        </div>

        {{! ── Activity / page header ── }}
        {{#headercontent}}
            <div style="margin-bottom:1.5rem;padding-bottom:1.25rem;border-bottom:1px solid var(--cm-border)">
                {{> core/activity_header }}
            </div>
        {{/headercontent}}

        {{! ── Two-column grid: main (3fr) + sidebar (1fr) ── }}
        <div style="display:grid;grid-template-columns:1fr;gap:1.5rem"
             class="cm-page-grid">

            {{! ── Main content ── }}
            <main id="cm-main" role="main">
                {{{ output.main_content }}}
                {{{ output.activity_navigation }}}
            </main>

            {{! ── Sidebar ── }}
            {{#hasblocks}}
                <aside id="cm-sidebar" aria-label="Sidebar blocks"
                       style="display:flex;flex-direction:column;gap:1rem">
                    {{{ sidepreblocks }}}
                </aside>
            {{/hasblocks}}

        </div>
    </div>

    {{! ══════════════════════════════════════
        FOOTER
    ══════════════════════════════════════ }}
    <footer id="cm-footer" style="padding:1.25rem 0">
        <div style="max-width:1280px;margin:0 auto;padding:0 1.25rem;
                    display:flex;flex-wrap:wrap;justify-content:space-between;
                    align-items:center;gap:0.75rem">
            <span>© {{sitename}}</span>
            <div style="display:flex;gap:1.5rem;align-items:center">
                {{{ output.home_link }}}
                {{{ output.login_info }}}
            </div>
        </div>
    </footer>

</div>

{{{ output.standard_after_main_region_html }}}
{{{ output.standard_end_of_body_html }}}

<style>
    /* Responsive grid — sidebar becomes bottom column on mobile */
    @media (min-width: 1024px) {
        .cm-page-grid { grid-template-columns: 1fr 300px !important; }
    }
    @media (max-width: 1023px) {
        #cm-sidebar { display: none; } /* collapse sidebar on small screens */
    }
</style>

<script>
(function () {
    'use strict';

    /* ── 1. Theme toggle ─────────────────────────────────────── */
    var themeBtn = document.getElementById('cm-theme-toggle');
    if (themeBtn) {
        themeBtn.addEventListener('click', function () {
            var isDark = document.documentElement.classList.toggle('dark');
            try { localStorage.setItem('cm-theme', isDark ? 'dark' : 'light'); } catch(e){}
            document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
        });
    }

    /* ── 2. Focus mode toggle ────────────────────────────────── */
    var focusBtn   = document.getElementById('cm-focus-toggle');
    var focusLabel = document.getElementById('cm-focus-label');
    function applyFocus(on) {
        document.body.classList.toggle('cm-focus-mode', on);
        if (focusBtn)   focusBtn.setAttribute('aria-pressed', String(on));
        if (focusLabel) focusLabel.textContent = on ? 'Exit Focus' : 'Focus';
        try { localStorage.setItem('cm-focus', on ? '1' : '0'); } catch(e){}
    }
    /* restore from storage */
    try { if (localStorage.getItem('cm-focus') === '1') applyFocus(true); } catch(e){}
    if (focusBtn) {
        focusBtn.addEventListener('click', function () {
            applyFocus(!document.body.classList.contains('cm-focus-mode'));
        });
    }

    /* ── 3. Reading progress bar ─────────────────────────────── */
    var bar = document.getElementById('cm-read-progress');
    if (bar) {
        function updateProgress() {
            var scrolled = window.scrollY || document.documentElement.scrollTop;
            var total    = document.documentElement.scrollHeight - window.innerHeight;
            var pct      = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
            bar.style.width = pct + '%';
        }
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
    }

    /* ── 4. Keyboard shortcut: F = toggle focus, D = toggle dark ─ */
    document.addEventListener('keydown', function (e) {
        /* Ignore when typing in inputs */
        if (['INPUT','TEXTAREA','SELECT'].indexOf(document.activeElement.tagName) !== -1) return;
        if (e.key === 'f' || e.key === 'F') {
            applyFocus(!document.body.classList.contains('cm-focus-mode'));
        }
        if (e.key === 'd' || e.key === 'D') {
            if (themeBtn) themeBtn.click();
        }
    });

})();
</script>

</body>
</html>
