    @template theme_rak/columns2
    @copyright 2024 RAK Theme
    @license   http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later

    RAK Theme — Two-column layout with sidebar-mini.
    The sidebar (#nav-drawer) is 64px wide by default.
    It expands to 240px on :hover via CSS (post.scss).
    This keeps the content area maximised at rest.

    Context variables required for this template:
    * sitename
    * output
    * bodyattributes
    * sidepreblocks
    * hasblocks
    * headercontent
    * overflow
    * primarynavigation
    * usermenu
    * langmenu
    * courseindexopen
    * addblockbutton
    * mobileprimarynav
    * courseindex
    * blockdrawer
    * regionmainsettingsmenu
    * hasregionmainsettingsmenu
    * cachecheck
    * activitynavigation
}}
<!DOCTYPE html>
<html {{{htmlattributes}}}>
<head>
    <title>{{pagetitle}}</title>
    <html-head-content/>
    {{> theme_rak/head_extra}}
</head>
<body {{{bodyattributes}}}>

{{> core/local/toast/wrapper}}

<div id="page-wrapper" class="d-print-block">

    {{{output.standard_top_of_body_html}}}

    {{> core/navbar}}

    {{! ── Drawer: Course Index (left side) ── }}
    {{#courseindexopen}}
        {{> theme_boost/drawers-courseindex}}
    {{/courseindexopen}}

    {{! ── Sidebar mini ── }}
    <div id="nav-drawer" data-region="fixed-drawer"
         class="d-print-none"
         aria-label="{{#str}} courseindex, core {{/str}}">
        <nav>
            {{{courseindex}}}
        </nav>
    </div>

    {{! ── Main page ── }}
    <div id="page" class="drawers {{#courseindexopen}}show-drawer-left{{/courseindexopen}} {{#hasblocks}}show-drawer-right{{/hasblocks}}">

        {{! Page header region }}
        <div id="topofscroll" class="main-inner">
            <div id="page-header" class="d-print-block mb-3">
                {{{headercontent}}}
            </div>

            {{! Region main settings menu }}
            {{#hasregionmainsettingsmenu}}
            <div id="region-main-settings-menu" class="d-print-none">
                {{{ regionmainsettingsmenu }}}
            </div>
            {{/hasregionmainsettingsmenu}}

            {{! ── Content + Optional Sidebar ── }}
            <div id="region-main-content" class="d-flex gap-3 align-items-start">

                {{! Main content }}
                <section id="region-main" class="flex-grow-1 overflow-auto" aria-label="{{#str}} content {{/str}}">
                    {{#overflow}}
                    <div data-region="overflow-hidden">
                    {{/overflow}}

                        {{{output.course_content_header}}}

                        {{! Activity navigation top }}
                        {{#activitynavigation}}
                            {{{.}}}
                        {{/activitynavigation}}

                        {{{output.main_content}}}

                        {{! Activity navigation bottom }}
                        {{#activitynavigation}}
                            {{{.}}}
                        {{/activitynavigation}}

                        {{{output.activity_navigation}}}
                        {{{output.course_content_footer}}}

                    {{#overflow}}
                    </div>
                    {{/overflow}}
                </section>

                {{! Side-pre blocks (right column) }}
                {{#hasblocks}}
                <aside id="block-region-side-pre"
                       class="block-region d-print-none"
                       data-blockregion="side-pre"
                       data-droptarget="1"
                       style="min-width:260px;max-width:300px;">
                    {{{sidepreblocks}}}
                    {{{addblockbutton}}}
                </aside>
                {{/hasblocks}}

            </div>{{! end #region-main-content }}

        </div>{{! end .main-inner }}

        {{{output.standard_after_main_region_html}}}

        {{! Footer }}
        <footer id="page-footer" class="py-3 bg-white border-top">
            <div class="container-fluid">
                {{{output.page_doc_link}}}
                {{{output.login_info}}}
                {{{output.home_link}}}
                {{{output.standard_footer_html}}}
            </div>
        </footer>

    </div>{{! end #page }}

    {{! Block drawer overlay }}
    {{#blockdrawer}}
        {{> theme_boost/drawers-blocks}}
    {{/blockdrawer}}

    {{! Cache check }}
    {{{cachecheck}}}

    {{! Scroll-to-top + Focus-mode buttons are injected by AMD }}

    {{{output.standard_end_of_body_html}}}

</div>{{! end #page-wrapper }}

</body>
</html>
